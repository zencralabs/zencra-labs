# ─── Copy this file to .env.local and fill in your values ───────────────────
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.zencralabs.com

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Verify sender domain in Resend dashboard → resend.com/domains
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=support@zencralabs.com
RESEND_FROM_NAME=Zencra Labs

# ── Twilio (SMS / WhatsApp / voice OTP) ───────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACe6b...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Auth — Email lock window ───────────────────────────────────────────────────
# Number of hours a user can change their email after subscription purchase (default: 2)
NEXT_PUBLIC_EMAIL_LOCK_WINDOW_HOURS=2

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Create a Turnstile site at: https://dash.cloudflare.com → Turnstile
#   Site name:   Zencra Auth
#   Domains:     zencralabs.com, localhost
#   Widget type: Managed (recommended)
# Copy both keys below. Then enable CAPTCHA in Supabase:
#   Supabase Dashboard → Auth → Settings → Enable CAPTCHA → Cloudflare Turnstile
#   Paste the SAME site key + secret key there.
#
# IMPORTANT: Do NOT enable CAPTCHA in Supabase before the frontend sends captchaToken.
# IMPORTANT: Never commit the secret key to git.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key   # exposed to browser — safe to be public
TURNSTILE_SECRET_KEY=your-turnstile-secret-key           # server-side only — keep secret

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
# Then add Client ID + Secret in Supabase Dashboard → Auth → Providers → Google
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# ── OAuth — Apple ─────────────────────────────────────────────────────────────
# Create at: https://developer.apple.com/account/resources/identifiers
# Service ID: com.zencralabs.app.signin
# Redirect URL: https://your-project.supabase.co/auth/v1/callback
# Add in Supabase Dashboard → Auth → Providers → Apple
APPLE_SERVICE_ID=com.zencralabs.app.signin
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
# Contents of AuthKey_XXXXX.p8 (keep line breaks as \n)
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── OAuth — Facebook ──────────────────────────────────────────────────────────
# Create at: https://developers.facebook.com → My Apps → Create App → Consumer
# App Domains: zencralabs.com
# Valid OAuth Redirect URIs: https://your-project.supabase.co/auth/v1/callback
# Add in Supabase Dashboard → Auth → Providers → Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# GPT Image model IDs — defaults shown below; override only if OpenAI changes the API string.
# gpt-image-1.5 is the current production model. gpt-image-2 is the next generation.
GPT_IMAGE_MODEL_ID=gpt-image-1.5
GPT_IMAGE_2_MODEL_ID=gpt-image-2

# ── Nano Banana (image generation) ────────────────────────────────────────────
NANO_BANANA_API_KEY=your-nano-banana-key
NANO_BANANA_ENABLE_V2=true
# NB2 endpoint — defaults to /api/v1/nanobanana/generate (same as Standard).
# Set this if your reseller account has a dedicated NB2 path confirmed in the dashboard,
# e.g. NANO_BANANA_NB2_ENDPOINT=/api/v1/nanobanana/generate-v2
# NANO_BANANA_NB2_ENDPOINT=/api/v1/nanobanana/generate

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-secret-here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...


# ── Kling AI (video generation) ───────────────────────────────────────────────
# Create at: https://klingai.com → API Keys
# Format: "accessKeyId:accessKeySecret" (preferred) or plain Bearer token
KLING_API_KEY=your-kling-access-key-id:your-kling-access-key-secret
KLING_BASE_URL=https://api.klingai.com
# Optional: override Kling 3.0 Omni model ID (defaults to kling-v3-omni)
# Set this if the Kling API uses a different ID string for the Omni variant.
# KLING_MODEL_OMNI=kling-v3-omni

# ── fal.ai (image + video + character via fal.ai queue) ──────────────────────
# Create at: https://fal.ai → API Keys
# Used for: Seedream v5/v4.5 (image), Flux Kontext (image),
#            Instant Character (character/influencer), FLUX fallback (character)
FAL_KEY=your-fal-ai-key
# Optional: override fal.ai model endpoint strings (defaults shown)
# FAL_MODEL_INSTANT_CHARACTER=fal-ai/instant-character
# FAL_MODEL_FLUX_CHARACTER=fal-ai/flux-pro

# ── Black Forest Labs (BFL) — direct FLUX Kontext API ────────────────────────
# Create at: https://api.bfl.ai → API Keys
# Used for: AI Influencer Look Pack generation (identity-preserving image variation)
# Architecture note: bfl-kontext provider uses direct BFL API, NOT fal-hosted flux-kontext.
#   Instant Character (fal.ai) → influencer candidate generation
#   bfl-kontext (direct BFL)   → Look Pack (identity-preserving variation)
#   flux-kontext (fal.ai)      → Image Studio general context editing
BFL_API_KEY=your-bfl-api-key
# Optional: override the BFL model endpoint (default: flux-kontext-pro)
# Options: flux-kontext-pro | flux-kontext-max (max = premium tier, not exposed in UI yet)
# BFL_KONTEXT_ENDPOINT=flux-kontext-pro

# ── BytePlus / Seedance (video generation) ────────────────────────────────────
# Create at: https://console.volcengine.com → ARK → API Keys
# Used for Seedance 2.0, Seedance 2.0 Fast, and Seedance 1.5 models (BytePlus ModelArk API)
BYTEPLUS_API_KEY=your-byteplus-ark-api-key
# Optional: override default Seedance model IDs
# SEEDANCE_MODEL_ID=dreamina-seedance-2-0-260128
# SEEDANCE_FAST_MODEL_ID=dreamina-seedance-2-0-fast-260128
# SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# Seedance 1.5 — NO default is provided intentionally.
# This model requires a verified BytePlus / Volcengine model endpoint ID before it can be used.
# Find the ID in: Volcengine console → ARK → Models → Seedance 1.5
# Without this variable set (and server redeployed), the model will show
# a "Not Configured" screen in the Video Studio UI rather than silently failing.
# SEEDANCE_15_MODEL_ID=

# ── ElevenLabs (Audio Studio — TTS, Phase 1 active) ──────────────────────────
# Create at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── Kits AI (Audio Studio — voice conversion, Phase 2) ───────────────────────
# NOT active in Phase 1. Set when Phase 2 launches.
# Create at: https://kits.ai → Dashboard → API
# KITS_API_KEY=your-kits-ai-key
# KITS_BASE_URL=https://arpeggi.io/api/kits/v1

# ── Stability AI (Character Studio — image gen, Phase 1 active) ──────────────
# Create at: https://platform.stability.ai → API Keys
STABILITY_API_KEY=your-stability-api-key
# Optional: override Stability base URL
# STABILITY_BASE_URL=https://api.stability.ai

# ── Runway ML (Video Studio — coming soon) ────────────────────────────────────
# NOT active in Phase 1. Set when Phase 2 Gen-4.5 launches.
# Create at: https://app.runwayml.com → API
# RUNWAY_API_KEY=your-runway-api-key
# RUNWAY_API_VERSION=2024-11-06

# ── Creatify (UGC Studio — product URL → video ad) ────────────────────────────
# Create at: https://creatify.ai → API
CREATIFY_API_KEY=your-creatify-api-key
CREATIFY_API_ID=your-creatify-api-id
# Optional: override base URL
# CREATIFY_BASE_URL=https://api.creatify.ai

# ── Arcads (UGC Studio — script + actor → video ad) ──────────────────────────
# Create at: https://arcads.ai → API
ARCADS_API_KEY=your-arcads-api-key
# Optional: override base URL
# ARCADS_BASE_URL=https://api.arcads.ai

# ── HeyGen UGC (UGC Studio — avatar ad engine) ────────────────────────────────
# NOTE: This is the UGC ad engine key. The Video Studio avatar key (if separate)
# uses the same env var — HeyGen uses a single API key across both use cases.
# Create at: https://app.heygen.com → API Tokens
HEYGEN_UGC_API_KEY=your-heygen-api-key
# Optional: override base URL (both HeyGen studio uses share this base)
# HEYGEN_UGC_BASE_URL=https://api.heygen.com

# ── LTX Video (FCS Studio — frame capture, fully isolated) ───────────────────
# Create at: https://app.ltx.studio → API
# Note: FCS is a restricted-access studio gated by hasFCSAccess().
# These env vars are only needed for users on FCS-enabled plans.
LTX_API_KEY=your-ltx-api-key
# Optional: override LTX base URL (defaults to https://api.ltx.studio)
# LTX_BASE_URL=https://api.ltx.studio

# ── Private Preview Gate ──────────────────────────────────────────────────────
# Set to "true" to enable the full-screen access-code gate before the homepage.
# When false (or absent) the homepage loads immediately with zero flicker.
# Access codes are managed in the private_preview_access table (service-role only).
NEXT_PUBLIC_ZENCRA_PREVIEW_GATE=false

# ── Provider Feature Flags (optional overrides) ───────────────────────────────
# Override phase defaults to enable/disable specific providers without code changes.
# Format: ZENCRA_FLAG_<STUDIO>_<PROVIDER>=true|false
# Examples:
# ZENCRA_FLAG_IMAGE_GPT_IMAGE=true
# ZENCRA_FLAG_VIDEO_KLING=true
# ZENCRA_FLAG_VIDEO_RUNWAY=false
# ZENCRA_FLAG_AUDIO_ELEVENLABS=true
# ZENCRA_FLAG_UGC_CREATIFY=true
# ZENCRA_FLAG_UGC_ARCADS=true
# ZENCRA_FLAG_UGC_HEYGEN_UGC=true
#
# Enable dry-run mode (estimates credits, skips actual API calls):
# ZENCRA_DRY_RUN=true
#
# Motion provider selection for Character Studio (defaults to "kling"):
# MOTION_PROVIDER=kling

# ─── Claude (Anthropic) ───────────────────────────────────────────────────────
# Used for all Claude-powered text enhancement (TextNode ✦ Enhance, future AI tools).
# Single source of truth: /lib/ai/claudeEnhancer.ts
ANTHROPIC_API_KEY=

# ─── Zencra Shield — Security Event Bus ─────────────────────────────────────
# Platform Shield: real-time security event bus, velocity scoring, circuit breakers.
# All systems default to "dry-run" — safe to deploy without configuring these.
#
# SHIELD_MODE controls the global operating mode for all protection systems:
#   dry-run  — log events only; zero enforcement action (DEFAULT, safe on day 1)
#   observe  — log + Discord alert; no blocking or circuit breaking
#   enforce  — log + alert + enforcement (block requests, open circuits, cancel jobs)
# Per-subsystem modes inherit from SHIELD_MODE unless overridden here.

SHIELD_MODE=dry-run

# Per-subsystem mode overrides (set to dry-run | observe | enforce | inherit)
# "inherit" = read global SHIELD_MODE at runtime (default for all subsystems)
VELOCITY_SCORER_MODE=inherit
CIRCUIT_BREAKER_MODE=inherit
WEBHOOK_ENFORCEMENT_MODE=inherit

# Discord Security Webhook — where Shield alerts are sent in observe/enforce mode
# Create a Discord channel webhook: Channel Settings → Integrations → Webhooks
# Leave blank to disable Discord alerting (events are still logged to stdout)
DISCORD_SECURITY_WEBHOOK_URL=

# User IDs exempt from velocity/entitlement enforcement (comma-separated UUIDs)
# Use for founder accounts and QA accounts during testing. Empty = no bypasses.
SHIELD_BYPASS_USER_IDS=

# Velocity scoring thresholds (per-user request counts)
# Warning tier: elevated scrutiny, Discord alert in observe/enforce mode
# Critical tier: request blocking in enforce mode
VELOCITY_WARNING_PER_5MIN=20
VELOCITY_CRITICAL_PER_5MIN=40

# Credit burn rate thresholds (credits consumed per hour per user)
CREDIT_BURN_WARNING_PER_HOUR=500
CREDIT_BURN_CRITICAL_PER_HOUR=2000

# Provider circuit breaker config
# Error rate threshold (0.0–1.0) at which provider enters DEGRADED state (traffic still flows)
CIRCUIT_BREAKER_DEGRADED_THRESHOLD=0.15
# Error rate threshold (0.0–1.0) above which a stabilized DEGRADED provider is isolated (OPEN)
CIRCUIT_BREAKER_ERROR_THRESHOLD=0.30
# Error rate threshold (0.0–1.0) below which DEGRADED provider self-heals back to CLOSED
CIRCUIT_BREAKER_RECOVERY_THRESHOLD=0.05
# Rolling window over which error rate is measured (seconds)
CIRCUIT_BREAKER_WINDOW_SECONDS=120
# Time (seconds) DEGRADED must persist before transitioning to OPEN (anti-flap stabilization)
CIRCUIT_BREAKER_STABILIZATION_SECONDS=30
# Consecutive successful probe requests required before HALF_OPEN → CLOSED (gradual recovery)
CIRCUIT_BREAKER_PROBES_TO_RECOVER=3

# ─────────────────────────────────────────────────────────────────────────────
# Webhook Signature Verification (Zencra Shield — Batch 3)
# ─────────────────────────────────────────────────────────────────────────────
# WEBHOOK_ENFORCEMENT_MODE controls what happens when verification fails.
# All modes always log and (in observe/enforce) alert Discord.
#
#   dry-run  — log only; always proceed (safe during provider onboarding)
#   observe  — Discord alert; always proceed (permissive — recommended default)
#   enforce  — Discord alert; return 401 on invalid/missing/replay signature
#
# Start in observe or dry-run. Switch to enforce only after confirming all
# provider secrets are correctly configured and no false positives are seen.
# Overrides global SHIELD_MODE for webhook verification only.
# "inherit" = read global SHIELD_MODE at runtime (default).
#
# WEBHOOK_ENFORCEMENT_MODE is already declared above in the Shield section.
# Replay protection: reject webhooks with a timestamp older than this value.
WEBHOOK_REPLAY_WINDOW_SECONDS=300

# Per-provider HMAC secrets — set in each provider's dashboard / webhook config.
# Leave blank to skip verification for that provider (logs at info level).
# These secrets are used exclusively for HMAC-SHA256 signature verification.
# Never share these with client-side code — server-side only.
FAL_WEBHOOK_SECRET=
KLING_WEBHOOK_SECRET=
BYTEPLUS_WEBHOOK_SECRET=
RUNWAY_WEBHOOK_SECRET=
HEYGEN_WEBHOOK_SECRET=
CREATIFY_WEBHOOK_SECRET=
ARCADS_WEBHOOK_SECRET=
OPENAI_WEBHOOK_SECRET=
# Nano Banana does not sign webhooks — this var is reserved for future use.
NANO_BANANA_WEBHOOK_SECRET=

# ── Cron / Internal Automation ────────────────────────────────────────────────
# High-entropy random string used to authenticate Vercel Cron requests.
# Generate with: openssl rand -hex 32
# Used by: POST /api/workflows/recover-stale (Phase 2D stale-run recovery)
CRON_SECRET=
