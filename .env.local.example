# ─────────────────────────────────────────────────────────────────────────────
# ZENCRA LABS – Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Server-side only, never expose

# ── AI APIs ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Site URL (used for metadata and OG images) ────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://zencralabs.com

# ── Razorpay (add when ready for payments) ───────────────────────────────────
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...
