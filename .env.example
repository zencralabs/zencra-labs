# ─── Copy this file to .env.local and fill in your values ───────────────────
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.zencralabs.com

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Verify sender domain in Resend dashboard → resend.com/domains
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=support@zencralabs.com
RESEND_FROM_NAME=Zencra Labs

# ── Twilio (SMS / WhatsApp / voice OTP) ───────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACe6b...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Auth — Email lock window ───────────────────────────────────────────────────
# Number of hours a user can change their email after subscription purchase (default: 2)
NEXT_PUBLIC_EMAIL_LOCK_WINDOW_HOURS=2

# ── Cloudflare Turnstile (CAPTCHA) ────────────────────────────────────────────
# Create a Turnstile site at: https://dash.cloudflare.com → Turnstile
#   Site name:   Zencra Auth
#   Domains:     zencralabs.com, localhost
#   Widget type: Managed (recommended)
# Copy both keys below. Then enable CAPTCHA in Supabase:
#   Supabase Dashboard → Auth → Settings → Enable CAPTCHA → Cloudflare Turnstile
#   Paste the SAME site key + secret key there.
#
# IMPORTANT: Do NOT enable CAPTCHA in Supabase before the frontend sends captchaToken.
# IMPORTANT: Never commit the secret key to git.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key   # exposed to browser — safe to be public
TURNSTILE_SECRET_KEY=your-turnstile-secret-key           # server-side only — keep secret

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-project.supabase.co/auth/v1/callback
# Then add Client ID + Secret in Supabase Dashboard → Auth → Providers → Google
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# ── OAuth — Apple ─────────────────────────────────────────────────────────────
# Create at: https://developer.apple.com/account/resources/identifiers
# Service ID: com.zencralabs.app.signin
# Redirect URL: https://your-project.supabase.co/auth/v1/callback
# Add in Supabase Dashboard → Auth → Providers → Apple
APPLE_SERVICE_ID=com.zencralabs.app.signin
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
# Contents of AuthKey_XXXXX.p8 (keep line breaks as \n)
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── OAuth — Facebook ──────────────────────────────────────────────────────────
# Create at: https://developers.facebook.com → My Apps → Create App → Consumer
# App Domains: zencralabs.com
# Valid OAuth Redirect URIs: https://your-project.supabase.co/auth/v1/callback
# Add in Supabase Dashboard → Auth → Providers → Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Nano Banana (image generation) ────────────────────────────────────────────
NANO_BANANA_API_KEY=your-nano-banana-key
NANO_BANANA_ENABLE_V2=true
# NB2 endpoint — defaults to /api/v1/nanobanana/generate (same as Standard).
# Set this if your reseller account has a dedicated NB2 path confirmed in the dashboard,
# e.g. NANO_BANANA_NB2_ENDPOINT=/api/v1/nanobanana/generate-v2
# NANO_BANANA_NB2_ENDPOINT=/api/v1/nanobanana/generate

# ── Razorpay (payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-secret-here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...


# ── Kling AI (video generation) ───────────────────────────────────────────────
# Create at: https://klingai.com → API Keys
# Format: "accessKeyId:accessKeySecret" (preferred) or plain Bearer token
KLING_API_KEY=your-kling-access-key-id:your-kling-access-key-secret
KLING_BASE_URL=https://api.klingai.com
# Optional: override Kling 3.0 Omni model ID (defaults to kling-v3-omni)
# Set this if the Kling API uses a different ID string for the Omni variant.
# KLING_MODEL_OMNI=kling-v3-omni

# ── fal.ai (image + video via fal.ai queue) ──────────────────────────────────
# Create at: https://fal.ai → API Keys
# Used for: Seedream v5/v4.5 (image), Flux Kontext (image), FLUX (character gen)
FAL_KEY=your-fal-ai-key

# ── BytePlus / Seedance (video generation) ────────────────────────────────────
# Create at: https://console.volcengine.com → ARK → API Keys
# Used for Seedance 2.0, Seedance 2.0 Fast, and Seedance 1.5 models (BytePlus ModelArk API)
BYTEPLUS_API_KEY=your-byteplus-ark-api-key
# Optional: override default Seedance model IDs
# SEEDANCE_MODEL_ID=dreamina-seedance-2-0-260128
# SEEDANCE_FAST_MODEL_ID=dreamina-seedance-2-0-fast-260128
# SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# Seedance 1.5 — NO default is provided intentionally.
# This model requires a verified BytePlus / Volcengine model endpoint ID before it can be used.
# Find the ID in: Volcengine console → ARK → Models → Seedance 1.5
# Without this variable set (and server redeployed), the model will show
# a "Not Configured" screen in the Video Studio UI rather than silently failing.
# SEEDANCE_15_MODEL_ID=

# ── ElevenLabs (Audio Studio — TTS, Phase 1 active) ──────────────────────────
# Create at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── Kits AI (Audio Studio — voice conversion, Phase 2) ───────────────────────
# NOT active in Phase 1. Set when Phase 2 launches.
# Create at: https://kits.ai → Dashboard → API
# KITS_API_KEY=your-kits-ai-key
# KITS_BASE_URL=https://arpeggi.io/api/kits/v1

# ── Stability AI (Character Studio — image gen, Phase 1 active) ──────────────
# Create at: https://platform.stability.ai → API Keys
STABILITY_API_KEY=your-stability-api-key
# Optional: override Stability base URL
# STABILITY_BASE_URL=https://api.stability.ai

# ── Runway ML (Video Studio — coming soon) ────────────────────────────────────
# NOT active in Phase 1. Set when Phase 2 Gen-4.5 launches.
# Create at: https://app.runwayml.com → API
# RUNWAY_API_KEY=your-runway-api-key
# RUNWAY_API_VERSION=2024-11-06

# ── Creatify (UGC Studio — product URL → video ad) ────────────────────────────
# Create at: https://creatify.ai → API
CREATIFY_API_KEY=your-creatify-api-key
CREATIFY_API_ID=your-creatify-api-id
# Optional: override base URL
# CREATIFY_BASE_URL=https://api.creatify.ai

# ── Arcads (UGC Studio — script + actor → video ad) ──────────────────────────
# Create at: https://arcads.ai → API
ARCADS_API_KEY=your-arcads-api-key
# Optional: override base URL
# ARCADS_BASE_URL=https://api.arcads.ai

# ── HeyGen UGC (UGC Studio — avatar ad engine) ────────────────────────────────
# NOTE: This is the UGC ad engine key. The Video Studio avatar key (if separate)
# uses the same env var — HeyGen uses a single API key across both use cases.
# Create at: https://app.heygen.com → API Tokens
HEYGEN_UGC_API_KEY=your-heygen-api-key
# Optional: override base URL (both HeyGen studio uses share this base)
# HEYGEN_UGC_BASE_URL=https://api.heygen.com

# ── LTX Video (FCS Studio — frame capture, fully isolated) ───────────────────
# Create at: https://app.ltx.studio → API
# Note: FCS is a restricted-access studio gated by hasFCSAccess().
# These env vars are only needed for users on FCS-enabled plans.
LTX_API_KEY=your-ltx-api-key
# Optional: override LTX base URL (defaults to https://api.ltx.studio)
# LTX_BASE_URL=https://api.ltx.studio

# ── Provider Feature Flags (optional overrides) ───────────────────────────────
# Override phase defaults to enable/disable specific providers without code changes.
# Format: ZENCRA_FLAG_<STUDIO>_<PROVIDER>=true|false
# Examples:
# ZENCRA_FLAG_IMAGE_GPT_IMAGE=true
# ZENCRA_FLAG_VIDEO_KLING=true
# ZENCRA_FLAG_VIDEO_RUNWAY=false
# ZENCRA_FLAG_AUDIO_ELEVENLABS=true
# ZENCRA_FLAG_UGC_CREATIFY=true
# ZENCRA_FLAG_UGC_ARCADS=true
# ZENCRA_FLAG_UGC_HEYGEN_UGC=true
#
# Enable dry-run mode (estimates credits, skips actual API calls):
# ZENCRA_DRY_RUN=true
#
# Motion provider selection for Character Studio (defaults to "kling"):
# MOTION_PROVIDER=kling
