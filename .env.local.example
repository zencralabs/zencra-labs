# ─────────────────────────────────────────────────────────────────────────────
# ZENCRA LABS – Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only — never expose

# ── OpenAI ───────────────────────────────────────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# ── Site URL (metadata and OG images) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://zencralabs.com

# ── Demo / Preview mode flags ────────────────────────────────────────────────
# Set both to true in .env.local or Vercel Preview env vars for demo billing.
# Leave unset (or false) in production.
BILLING_DEMO_MODE=true
DEMO_MODE=true

# ── Razorpay ─────────────────────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
# Not called when BILLING_DEMO_MODE=true — safe to leave as placeholder locally.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Stripe ───────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
# Not called when BILLING_DEMO_MODE=true — safe to leave as placeholder locally.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
